{
  "manifest_version": 3,
  "name": "RumbleTip",
  "version": "1.0.0",
  "description": "Tip Rumble creators via AI agent. Hover to see Alpha score and Tip via Agent.",
  "permissions": [],
  "host_permissions": [
    "https://rumble.com/*",
    "http://localhost:3000/*",
    "https://*.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://rumble.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
