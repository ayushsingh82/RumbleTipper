{
  "manifest_version": 3,
  "name": "Rumble Tipper",
  "version": "1.4.0",
  "description": "Rumble Tipper — Alpha scores and ETH tips on rumble.com; pairs with rumble-tipper.vercel.app.",
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://rumble.com/*",
    "http://localhost:3000/*",
    "https://*.vercel.app/*",
    "https://rumble-tipper.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://rumble.com/*"],
      "js": ["dom-reader.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
